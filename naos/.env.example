# ─── Notion ────────────────────────────────────────────────────────────────────
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Comma-separated database IDs to monitor
NOTION_DATABASE_IDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx,yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy

# ─── GitHub ─────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repository
# Must be 32+ chars for webhook signature verification
GITHUB_WEBHOOK_SECRET=your-very-long-secret-at-least-32-characters-long

# ─── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-5

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Safety (defaults are conservative — change deliberately) ──────────────────
DRY_RUN=true
REQUIRE_HUMAN_APPROVAL=true
MAX_ACTIONS_PER_RUN=10
# Optional: POST approval requests here
HUMAN_APPROVAL_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# ─── Performance ────────────────────────────────────────────────────────────────
CONTEXT_CACHE_TTL_SECONDS=300
MAX_CONCURRENT_AGENTS=3
API_TIMEOUT_MS=30000

# ─── Scheduling ─────────────────────────────────────────────────────────────────
# Cron expression for autonomous runs (default: every 30 minutes)
RUN_CRON=*/30 * * * *
# Port for webhook server
WEBHOOK_PORT=3000
